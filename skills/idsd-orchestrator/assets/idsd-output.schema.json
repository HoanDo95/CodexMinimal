{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "classification",
    "currentStage",
    "intentContract",
    "architectureDecisions",
    "boundedSpecification",
    "taskBreakdown",
    "testContract",
    "agentCards",
    "decisionLedgerEntries",
    "acceptanceEvidence",
    "protectedFileOrRiskConcerns",
    "nextSkill",
    "followUpChain",
    "stopCondition",
    "reportOutline",
    "suggestedPrompt"
  ],
  "properties": {
    "classification": {
      "type": "string",
      "enum": ["idsd"]
    },
    "currentStage": {
      "type": "string",
      "enum": ["intent", "architecture-decision", "specification", "task-breakdown", "tests", "implementation-handoff", "verification", "report"]
    },
    "intentContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "businessRules", "nonGoals", "constraints", "acceptanceCriteria"],
      "properties": {
        "intent": { "type": "string" },
        "businessRules": { "type": "array", "items": { "type": "string" } },
        "nonGoals": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "acceptanceCriteria": { "type": "array", "items": { "type": "string" } }
      }
    },
    "architectureDecisions": { "type": "array", "items": { "type": "string" } },
    "boundedSpecification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["behavior", "interfaces", "dataImpacts", "risks", "acceptanceMapping"],
      "properties": {
        "behavior": { "type": "array", "items": { "type": "string" } },
        "interfaces": { "type": "array", "items": { "type": "string" } },
        "dataImpacts": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "acceptanceMapping": { "type": "array", "items": { "type": "string" } }
      }
    },
    "taskBreakdown": { "type": "array", "items": { "type": "string" } },
    "testContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tddMode", "testPlan", "verificationAlternatives"],
      "properties": {
        "tddMode": { "type": "string", "enum": ["test-first-required", "test-plan-only", "manual-verification-acceptable", "not-applicable"] },
        "testPlan": { "type": "array", "items": { "type": "string" } },
        "verificationAlternatives": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agentCards": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["planner", "architect", "implementer", "verifier", "reviewer"]
      }
    },
    "decisionLedgerEntries": { "type": "array", "items": { "type": "string" } },
    "acceptanceEvidence": { "type": "array", "items": { "type": "string" } },
    "protectedFileOrRiskConcerns": { "type": "array", "items": { "type": "string" } },
    "nextSkill": { "type": "string" },
    "followUpChain": { "type": "array", "items": { "type": "string" } },
    "stopCondition": { "type": "string" },
    "reportOutline": { "type": "array", "items": { "type": "string" } },
    "suggestedPrompt": { "type": "string" }
  }
}
